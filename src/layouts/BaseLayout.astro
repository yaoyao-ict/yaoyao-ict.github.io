---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

const {
  title = "姚瑶",
  description = "姚瑶的个人网站，展示项目、文章、经历和联系方式。",
  home = false,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <Header home={home} />
    <main>
      <slot />
    </main>
    <Footer />
    <dialog class="search-dialog" data-search-dialog>
      <form method="dialog">
        <label for="site-search">搜索站内内容</label>
        <input id="site-search" type="search" placeholder="输入项目、文章或技能" />
        <button type="submit">关闭</button>
      </form>
    </dialog>
    <script is:inline src="/scripts/site.js"></script>
  </body>
</html>
