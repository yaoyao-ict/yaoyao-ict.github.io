---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

const {
  title = "YaoYao",
  description = "YaoYao's personal website, featuring projects, writing, experience, and contact information.",
  home = false,
  titleKey = "title.home",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;650;750;850&family=Plus+Jakarta+Sans:wght@400;500;650;750;800&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body data-title-key={titleKey}>
    <Header home={home} />
    <main>
      <slot />
    </main>
    <Footer />
    <dialog class="search-dialog" data-search-dialog>
      <form method="dialog">
        <label for="site-search" data-i18n="search.label">Search the site</label>
        <input id="site-search" type="search" placeholder="Search projects, writing, or skills" data-i18n-placeholder="search.placeholder" />
        <button type="submit" data-i18n="button.close">Close</button>
      </form>
    </dialog>
    <script is:inline src="/scripts/site.js"></script>
  </body>
</html>
