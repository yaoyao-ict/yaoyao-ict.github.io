---
import BaseLayout from "./BaseLayout.astro";

const {
  title,
  titleKey,
  subtitle,
  subtitleKey,
  eyebrow,
  toc = [],
} = Astro.props;
---

<BaseLayout title={title} titleKey={titleKey}>
  <article class="article-shell">
    <header class="article-header">
      <p class="eyebrow">{eyebrow}</p>
      <h1 class="article-title" data-i18n={titleKey}>{title}</h1>
      {subtitle && <p class="article-subtitle" data-i18n={subtitleKey}>{subtitle}</p>}
    </header>

    <div class="article-grid">
      <aside class="toc" aria-label="Table of contents">
        <h2 data-i18n="article.toc">Table of Contents</h2>
        {toc.map((item) => <a href={`#${item.id}`} data-i18n={item.key}>{item.label}</a>)}
      </aside>
      <div class="article-content">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>
