---
import BaseLayout from "./BaseLayout.astro";
import AntPageHeader from "../components/react/AntPageHeader.jsx";
import { getBreadcrumbs } from "../data/breadcrumbs.js";

const {
  title,
  titleKey,
  subtitle,
  subtitleKey,
  eyebrow,
  toc = [],
} = Astro.props;

const breadcrumbs = getBreadcrumbs(Astro.url.pathname);
---

<BaseLayout title={title} titleKey={titleKey}>
  <article class="article-shell">
    <AntPageHeader eyebrow={eyebrow} title={title} lead={subtitle} titleKey={titleKey} leadKey={subtitleKey} breadcrumbs={breadcrumbs} />

    <div class="article-grid">
      <aside class="toc" aria-label="Table of contents">
        <h2 data-i18n="article.toc">Table of Contents</h2>
        {toc.map((item) => <a href={`#${item.id}`} data-i18n={item.key}>{item.label}</a>)}
      </aside>
      <div class="article-content">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>
