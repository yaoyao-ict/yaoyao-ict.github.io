---
import AntPageHeader from "./react/AntPageHeader.jsx";
import { getBreadcrumbs } from "../data/breadcrumbs.js";

const { eyebrow, title, lead, titleKey, leadKey } = Astro.props;
const breadcrumbs = getBreadcrumbs(Astro.url.pathname);
---

<AntPageHeader eyebrow={eyebrow} title={title} lead={lead} titleKey={titleKey} leadKey={leadKey} breadcrumbs={breadcrumbs} />
