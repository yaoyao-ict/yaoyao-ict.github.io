---
import ArticleLayout from "../../../../layouts/ArticleLayout.astro";

const toc = [
  { id: "context", label: "Context", key: "article.section.context" },
  { id: "approach", label: "Approach", key: "article.section.approach" },
  { id: "outcome", label: "Outcome", key: "article.section.outcome" },
];
---

<ArticleLayout
  title="Smart Dashboard"
  titleKey="article.smartDashboard.title"
  subtitle="A practical dashboard project focused on making key metrics easier to scan, compare, and act on."
  subtitleKey="article.smartDashboard.description"
  eyebrow="Data"
  toc={toc}
>
  <section id="context">
    <h2 data-i18n="article.section.context">Context</h2>
    <p data-i18n="article.smartDashboard.context">
      The dashboard is designed for recurring business reviews where people need a fast read on performance, exceptions, and next actions.
    </p>
  </section>

  <section id="approach">
    <h2 data-i18n="article.section.approach">Approach</h2>
    <p data-i18n="article.smartDashboard.approach">
      I would keep the first screen focused on comparison, trend, and risk signals, then move detailed tables into secondary sections.
    </p>
  </section>

  <section id="outcome">
    <h2 data-i18n="article.section.outcome">Outcome</h2>
    <p data-i18n="article.smartDashboard.outcome">
      The result is a dashboard structure that helps users scan the same metrics consistently without reading a long report every time.
    </p>
  </section>
</ArticleLayout>
