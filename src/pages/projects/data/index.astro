---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHeader from "../../../components/PageHeader.astro";
import CollectionList from "../../../components/CollectionList.astro";
import { dataArticles } from "../../../data/navigation.js";
---

<BaseLayout title="Data Projects | YaoYao" titleKey="title.projects.data">
  <section class="page-shell">
    <PageHeader
      eyebrow="Data"
      title="Data Dashboards"
      titleKey="page.projects.data.title"
      lead="Projects around data visualization, reporting, monitoring, and decision support."
      leadKey="page.projects.data.lead"
    />
    <CollectionList countLabel="2 Projects" countKey="collection.data.count" items={dataArticles} />
  </section>
</BaseLayout>
