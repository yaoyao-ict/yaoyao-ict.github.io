---
import ArticleLayout from "../../../../layouts/ArticleLayout.astro";

const toc = [
  { id: "context", label: "Context", key: "article.section.context" },
  { id: "approach", label: "Approach", key: "article.section.approach" },
  { id: "outcome", label: "Outcome", key: "article.section.outcome" },
];
---

<ArticleLayout
  title="Metrics Review System"
  titleKey="article.metricsReview.title"
  subtitle="A lightweight reporting structure for reviewing recurring metrics, changes, and follow-up actions."
  subtitleKey="article.metricsReview.description"
  eyebrow="Data"
  toc={toc}
>
  <section id="context">
    <h2 data-i18n="article.section.context">Context</h2>
    <p data-i18n="article.metricsReview.context">Recurring reviews need a consistent structure so changes and follow-ups do not disappear between meetings.</p>
  </section>
  <section id="approach">
    <h2 data-i18n="article.section.approach">Approach</h2>
    <p data-i18n="article.metricsReview.approach">The system groups metrics by owner, cadence, and action status while keeping raw detail available when needed.</p>
  </section>
  <section id="outcome">
    <h2 data-i18n="article.section.outcome">Outcome</h2>
    <p data-i18n="article.metricsReview.outcome">The page becomes a repeatable review surface rather than a one-off report.</p>
  </section>
</ArticleLayout>
