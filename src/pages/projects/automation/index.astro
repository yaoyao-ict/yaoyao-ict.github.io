---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHeader from "../../../components/PageHeader.astro";
import CollectionList from "../../../components/CollectionList.astro";
import { automationArticles } from "../../../data/navigation.js";
---

<BaseLayout title="Automation Projects | YaoYao" titleKey="title.projects.automation">
  <section class="page-shell">
    <PageHeader
      eyebrow="Automation"
      title="Automation Projects"
      titleKey="page.projects.automation.title"
      lead="Projects related to Python, APIs, Azure, internal tools, and workflow automation."
      leadKey="page.projects.automation.lead"
    />
    <CollectionList countLabel="2 Projects" countKey="collection.automation.count" items={automationArticles} />
  </section>
</BaseLayout>
