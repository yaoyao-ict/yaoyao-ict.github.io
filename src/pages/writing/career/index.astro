---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHeader from "../../../components/PageHeader.astro";
import CollectionList from "../../../components/CollectionList.astro";
import { careerArticles } from "../../../data/navigation.js";
---

<BaseLayout title="Career Growth | YaoYao" titleKey="title.writing.career">
  <section class="page-shell">
    <PageHeader
      eyebrow="Career"
      title="Career Growth"
      titleKey="page.writing.career.title"
      lead="Writing about portfolio work, project storytelling, collaboration, and reflection."
      leadKey="page.writing.career.lead"
    />
    <CollectionList countLabel="2 Essays" countKey="collection.career.count" items={careerArticles} />
  </section>
</BaseLayout>
