---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHeader from "../../../components/PageHeader.astro";
import CollectionList from "../../../components/CollectionList.astro";
import { deploymentArticles } from "../../../data/navigation.js";
---

<BaseLayout title="Deployment Notes | YaoYao" titleKey="title.writing.deployment">
  <section class="page-shell">
    <PageHeader
      eyebrow="Deployment"
      title="Deployment Notes"
      titleKey="page.writing.deployment.title"
      lead="Notes about building this site locally and publishing it with GitHub Pages."
      leadKey="page.writing.deployment.lead"
    />
    <CollectionList countLabel="2 Notes" countKey="collection.deployment.count" items={deploymentArticles} />
  </section>
</BaseLayout>
