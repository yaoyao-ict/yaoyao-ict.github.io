---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
---

<BaseLayout title="YaoYao" titleKey="title.home" home>
  <Hero />

  <section class="intro" aria-labelledby="intro-title">
    <p class="eyebrow">YaoYao</p>
    <h1 id="intro-title" data-i18n="home.hero.title">Hi, I'm YaoYao.</h1>
    <p data-i18n="home.hero.lead">
      I focus on turning complex problems into clear, reliable, and maintainable product experiences.
      This space can introduce my role, current interests, and the strengths I want people to remember.
    </p>
    <div class="intro-actions">
      <a class="primary-link" href="/projects/" data-i18n="home.cta.projects">View projects</a>
      <a class="secondary-link" href="/contact/" data-i18n="home.cta.contact">Contact me</a>
    </div>
  </section>

  <div class="content-grid">
    <section class="articles" aria-labelledby="work-title">
      <h2 id="work-title" class="section-title" data-i18n="home.featuredProjects">Featured Projects</h2>

      <article class="post featured">
        <a href="/projects/data/smart-dashboard/" class="post-title" data-i18n="home.project.data.title">Project One: Smart Dashboard</a>
        <p class="subtitle">React / TypeScript / Data Visualization</p>
        <p data-i18n="home.project.data.description">
          A concise summary of the problem, my role, and the outcome. This is the place for two or three
          focused lines rather than a long case study.
        </p>
      </article>

      <article class="post">
        <a href="/projects/automation/workflow-automation/" class="post-title" data-i18n="home.project.automation.title">Project Two: Automation Workflow</a>
        <p class="subtitle">Python / Azure / API Integration</p>
        <p data-i18n="home.project.automation.description">
          A project about reducing repetitive work by connecting systems, scripting workflows, and making
          daily operations more reliable.
        </p>
      </article>

      <article class="post">
        <a href="/projects/" class="post-title" data-i18n="home.project.knowledge.title">Project Three: Personal Knowledge Base</a>
        <p class="subtitle">Content System / Search / UX</p>
        <p data-i18n="home.project.knowledge.description">
          A hub for notes, writing, open-source work, or learning material that can grow over time.
        </p>
      </article>
    </section>

    <aside class="sidebar" aria-label="Side content">
      <section>
        <h2 class="section-title" data-i18n="home.about.title">About Me</h2>
        <p data-i18n="home.about.description">
          This section can hold a short introduction: who I am, what I work on, what I am good at, and what
          opportunities I am open to.
        </p>
      </section>

      <section class="skills">
        <h2 class="section-title" data-i18n="home.skills.title">Skills</h2>
        <div class="chips">
          <a href="/projects/">React</a>
          <a href="/projects/">TypeScript</a>
          <a href="/writing/deployment/">Azure</a>
          <a href="/projects/automation/">Python</a>
          <a href="/about/">Product</a>
          <a href="/projects/">Design Systems</a>
          <a href="/projects/automation/">Automation</a>
          <a href="/projects/data/">Data</a>
        </div>
      </section>
    </aside>
  </div>

  <section class="writing" aria-labelledby="writing-title">
    <h2 id="writing-title" class="section-title" data-i18n="home.recentWriting">Recent Writing</h2>
    <div class="writing-list">
      <a href="/writing/deployment/personal-website/">
        <span data-i18n="home.writing.website">Building a maintainable personal website</span>
        <small>Web / Deployment</small>
      </a>
      <a href="/writing/deployment/github-pages/">
        <span data-i18n="home.writing.pages">Publishing a static site with GitHub Pages</span>
        <small>GitHub / Deployment</small>
      </a>
      <a href="/writing/career/project-stories/">
        <span data-i18n="home.writing.portfolio">Writing project stories that feel like real work</span>
        <small>Career / Writing</small>
      </a>
    </div>
  </section>

  <section class="newsletter" aria-labelledby="contact-title">
    <div>
      <h2 id="contact-title" data-i18n="home.contact.title">Want to talk about a project, collaboration, or opportunity?</h2>
      <p data-i18n="home.contact.description">Replace this with my email, LinkedIn, GitHub, or a form service later.</p>
    </div>
    <div class="contact-links">
      <a href="mailto:you@example.com">you@example.com</a>
      <a href="https://github.com/yaoyao-ict">GitHub</a>
      <a href="https://www.linkedin.com/">LinkedIn</a>
    </div>
  </section>
</BaseLayout>
